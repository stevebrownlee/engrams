[flake8]
max-line-length = 88
# E203: whitespace before ':' (conflicts with Black)
# W503: line break before binary operator (conflicts with Black)
# E501: line too long (Black handles this, some lines intentionally over for readability)
# E402: module level import not at top of file (intentional lazy imports)
extend-ignore = E203, W503, E501, E402
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    *.egg-info,
    .mypy_cache,
    .pytest_cache,
    .tox,
    .eggs
